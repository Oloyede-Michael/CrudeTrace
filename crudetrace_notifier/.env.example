# Blockchain Configuration
# Use public endpoint or your Infura/Alchemy key
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# Telegram Bot Configuration
# Get from @BotFather on Telegram
# Visit: https://api.telegram.org/botYOUR_BOT_TOKEN/getUpdates to find your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Server Configuration
PORT=3001

# Webhook Configuration (only for production deployments)
# For local development, leave this commented out
# WEBHOOK_URL=https://your-domain.com